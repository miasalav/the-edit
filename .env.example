# ============================================================
# The Edit — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── Sanity (NEXT_PUBLIC_ = safe to expose in browser) ─────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# ── Sanity tokens (server only — NEVER prefix with NEXT_PUBLIC_) ──
# Read token: used for fetching draft content or bypassing CDN
SANITY_API_READ_TOKEN=

# Write token: used for server-side mutations (click tracking to Sanity)
# Leave blank if logging clicks to console only
SANITY_API_WRITE_TOKEN=

# ── Site URL (used for sitemap and OG image base URL) ──────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
